<script>
document.addEventListener('DOMContentLoaded', function() {
    // Financial Chart
    const months = @json(array_column($monthlyData, 'month'));
    const incomeData = @json(array_column($monthlyData, 'income'));
    const expenseData = @json(array_column($monthlyData, 'expense'));
    
    new Chart(document.getElementById('financialChart'), {
        type: 'line',
        data: {
            labels: months,
            datasets: [
                {
                    label: 'Income',
                    data: incomeData,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'Expenses',
                    data: expenseData,
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239, 68, 68, 0.1)',
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
    
    // Growth Chart
    const growthMonths = @json(array_column($growthData, 'month'));
    const membersCount = @json(array_column($growthData, 'members'));
    
    new Chart(document.getElementById('growthChart'), {
        type: 'bar',
        data: {
            labels: growthMonths,
            datasets: [{
                label: 'New Members',
                data: membersCount,
                backgroundColor: '#3b82f6',
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });
});
</script>
@endpush
